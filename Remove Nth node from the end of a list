/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    int sizeOfList(ListNode* head){
        ListNode* temp = head;
        int count=0;

        while(temp != NULL){
            count++;
            temp = temp->next;
        }
        return count;
    }
    ListNode* Solve(ListNode* head,int n,int size){
        if(!head) return NULL;
        if(size == 1 && n==1) return NULL;

        if(size == n){
            return head->next;
        }

        ListNode* curr = head;
        ListNode* prev = NULL;

        int count =  size - n ;
        while(count--){
            prev = curr;
            curr = curr->next;
        }

        prev ->next = curr->next;
        return head;
    }
    ListNode* removeNthFromEnd(ListNode* head, int n) {
        int size = sizeOfList(head);
        return Solve(head,n,size);
    }
};