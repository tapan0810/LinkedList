class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) {
        if(!head) return head;

        ListNode* dummy = new ListNode(0);
        dummy->next = head;

        ListNode* prev = dummy;
        ListNode* curr = head;

        while(curr){
            // check duplicate start
            if(curr->next && curr->val == curr->next->val){

                int val = curr->val;

                // delete entire group
                while(curr && curr->val == val){
                    ListNode* temp = curr;
                    curr = curr->next;
                    delete temp;
                }

                prev->next = curr;
            }
            else{
                prev = curr;
                curr = curr->next;
            }
        }

        return dummy->next;
    }
};