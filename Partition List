class Solution {
public:
    ListNode* connectLists(ListNode* head1, ListNode* head2) {
        if(!head1) return head2;

        ListNode* curr = head1;
        while(curr->next) {
            curr = curr->next;
        }

        curr->next = head2;
        return head1;
    }

    ListNode* Solve(ListNode* head, int x) {
        ListNode* temp = head;

        ListNode* smallDummy = new ListNode(0);
        ListNode* bigDummy = new ListNode(0);

        ListNode* small = smallDummy;
        ListNode* big = bigDummy;

        while(temp != NULL) {
            ListNode* nextNode = temp->next;  // save next
            temp->next = NULL;                // detach current node

            if(temp->val < x) {
                small->next = temp;
                small = small->next;
            }
            else {
                big->next = temp;
                big = big->next;
            }

            temp = nextNode;
        }

        return connectLists(smallDummy->next, bigDummy->next);
    }

    ListNode* partition(ListNode* head, int x) {
        return Solve(head, x);
    }
};
